{
  "firestore": {
    "database": "(default)",
    "location": "asia-southeast3",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "firestore.indexes.json",
      "**/.*",
      "**/node_modules/**",
      "_misc/**",
      "tests/**",
      "scripts/**",
      "test-files/**",
      "screenshots/**",
      "CLAUDE.md",
      "DEV.md",
      "SKILL.md",
      "qa-tester.skill",
      "**/*.py",
      "**/*.pyc",
      "**/*.ps1",
      "**/*.md",
      "**/test-results-*.json",
      "**/bug-report-*.json",
      "Procfile",
      "**/*.bat",
      "**/*.exe",
      "**/*.json",
      "agent-browser.json",
      ".mcp.json",
      "requirements.txt",
      "กลับบ้านทำอันนี้ก่อน.txt",
      "New Text Document.txt"
    ]
  }
}
